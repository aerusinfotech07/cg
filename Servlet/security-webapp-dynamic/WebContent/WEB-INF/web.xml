<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
  <display-name>Web Application Security Demo (no Maven)</display-name>

  <!-- ========== Security: role used by this app ========== -->
  <security-role>
    <description>Authenticated user role</description>
    <role-name>user</role-name>
  </security-role>

  <!-- ========== Security constraint: which URLs are protected ========== -->
  <security-constraint>
    <web-resource-collection>
      <web-resource-name>Protected area</web-resource-name>
      <url-pattern>/secure/*</url-pattern>
      <url-pattern>/info</url-pattern>
      <http-method-get/>
      <http-method-post/>
    </web-resource-collection>
    <auth-constraint>
      <description>Only users in role 'user' can access</description>
      <role-name>user</role-name>
    </auth-constraint>
    <!-- Force encryption: redirect HTTP to HTTPS -->
    <user-data-constraint>
      <description>Require HTTPS between browser and server</description>
      <transport-guarantee>CONFIDENTIAL</transport-guarantee>
    </user-data-constraint>
  </security-constraint>

  <!-- ========== How to authenticate: FORM-based login ========== -->
  <login-config>
    <auth-method>FORM</auth-method>
    <realm-name>Security Demo Realm</realm-name>
    <form-login-config>
      <form-login-page>/login.jsp</form-login-page>
      <form-error-page>/login-error.jsp</form-error-page>
    </form-login-config>
  </login-config>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
