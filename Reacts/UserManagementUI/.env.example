# API base URL (no trailing slash)
# - Basic Auth (MySQL): http://localhost:8084
# - JWT (MySQL):       http://localhost:8084
# - MongoDB:           http://localhost:8084  (or the URL where your MongoDB API runs)
REACT_APP_API_BASE_URL=http://localhost:8084

# Auth mode: none | basic | jwt
# none  = no login (e.g. original API or MongoDB API without auth)
# basic = HTTP Basic Auth (UserManagementNodeAPI-BasicAuth)
# jwt   = JWT (UserManagementNodeAPI-JWT or MongoDB API with JWT)
REACT_APP_AUTH_MODE=jwt
